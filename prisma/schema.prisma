generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  ORGANIZER
  USER
}

enum UserStatus {
  ACTIVE
  PENDING
  REJECTED
  INACTIVE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  WAITING_CONFIRMATION
  PAID
  FAILED
  REFUNDED
  NOT_REQUIRED
}

enum PaymentMethod {
  BANK_TRANSFER
  E_WALLET
  CASH_ON_VENUE
  FREE
}

enum TicketStatus {
  VALID
  USED
  CANCELLED
  EXPIRED
}

model User {
  id                    String             @id @default(cuid())
  name                  String
  email                 String             @unique
  password              String
  role                  UserRole           @default(USER)
  status                UserStatus         @default(ACTIVE)
  phone                 String?            @map("phone")
  avatarUrl             String?            @map("avatar_url")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  organizerProfile      OrganizerProfile?
  approvedOrganizers    OrganizerProfile[] @relation("OrganizerApprovedBy")
  bookings              Booking[]          @relation("BookingUser")
  verifiedBookings      Booking[]          @relation("BookingVerifiedBy")
  approvedBookings      Booking[]          @relation("BookingApprovedBy")
  tickets               Ticket[]           @relation("TicketOwner")
  checkedInTickets      Ticket[]           @relation("TicketCheckedInBy")
  favoriteEvents        FavoriteEvent[]
  eventReviews          EventReview[]
  activityLogs          ActivityLog[]

  @@index([role, status])
  @@index([status])
  @@map("users")
}

model OrganizerProfile {
  id               String    @id @default(cuid())
  userId           String    @unique @map("user_id")
  organizationName String    @map("organization_name")
  description      String?   @db.Text
  contactPerson    String?   @map("contact_person")
  phone            String?
  websiteUrl       String?   @map("website_url")
  logoUrl          String?   @map("logo_url")
  address          String?   @db.Text
  approvedAt       DateTime? @map("approved_at")
  approvedBy       String?   @map("approved_by")
  rejectionReason  String?   @map("rejection_reason") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver         User?     @relation("OrganizerApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  events           Event[]

  @@index([approvedBy])
  @@index([approvedAt])
  @@map("organizer_profiles")
}

model EventCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  events      Event[]

  @@index([name])
  @@map("event_categories")
}

model Event {
  id                String          @id @default(cuid())
  organizerProfileId String         @map("organizer_profile_id")
  categoryId        String          @map("category_id")
  title             String
  slug              String          @unique
  description       String          @db.Text
  startDatetime     DateTime        @map("start_datetime")
  endDatetime       DateTime        @map("end_datetime")
  locationName      String          @map("location_name")
  locationAddress   String?         @map("location_address") @db.Text
  city              String
  imageUrl          String?         @map("image_url")
  status            EventStatus     @default(DRAFT)
  visibility        EventVisibility @default(PUBLIC)
  publishedAt       DateTime?       @map("published_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  organizerProfile  OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Restrict)
  category          EventCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  ticketTypes       TicketType[]
  bookings          Booking[]
  tickets           Ticket[]
  favoriteEvents    FavoriteEvent[]
  eventReviews      EventReview[]

  @@index([organizerProfileId])
  @@index([categoryId])
  @@index([status, visibility])
  @@index([city, startDatetime])
  @@index([publishedAt])
  @@map("events")
}

model TicketType {
  id            String    @id @default(cuid())
  eventId       String    @map("event_id")
  name          String
  description   String?   @db.Text
  price         Decimal   @db.Decimal(12, 2)
  quota         Int
  maxPerBooking Int       @map("max_per_booking")
  salesStartAt  DateTime? @map("sales_start_at")
  salesEndAt    DateTime? @map("sales_end_at")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Restrict)
  bookingItems  BookingItem[]
  tickets       Ticket[]

  @@unique([eventId, name])
  @@index([eventId])
  @@index([isActive])
  @@index([salesStartAt, salesEndAt])
  @@map("ticket_types")
}

model Booking {
  id                 String        @id @default(cuid())
  bookingCode        String        @unique @map("booking_code")
  userId             String        @map("user_id")
  eventId            String        @map("event_id")
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(UNPAID) @map("payment_status")
  paymentMethod      PaymentMethod @map("payment_method")
  paymentProofUrl    String?       @map("payment_proof_url")
  paymentNotes       String?       @map("payment_notes") @db.Text
  paymentVerifiedAt  DateTime?     @map("payment_verified_at")
  paymentVerifiedBy  String?       @map("payment_verified_by")
  totalAmount        Decimal       @map("total_amount") @db.Decimal(12, 2)
  notes              String?       @db.Text
  expiresAt          DateTime?     @map("expires_at")
  approvedAt         DateTime?     @map("approved_at")
  approvedBy         String?       @map("approved_by")
  rejectedReason     String?       @map("rejected_reason") @db.Text
  rejectedAt         DateTime?     @map("rejected_at")
  cancelledReason    String?       @map("cancelled_reason") @db.Text
  cancelledAt        DateTime?     @map("cancelled_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  user               User          @relation("BookingUser", fields: [userId], references: [id], onDelete: Restrict)
  event              Event         @relation(fields: [eventId], references: [id], onDelete: Restrict)
  paymentVerifier    User?         @relation("BookingVerifiedBy", fields: [paymentVerifiedBy], references: [id], onDelete: SetNull)
  approver           User?         @relation("BookingApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  items              BookingItem[]
  tickets            Ticket[]
  review             EventReview?

  @@index([userId])
  @@index([eventId])
  @@index([status, paymentStatus])
  @@index([paymentVerifiedBy])
  @@index([approvedBy])
  @@index([expiresAt])
  @@map("bookings")
}

model BookingItem {
  id           String    @id @default(cuid())
  bookingId    String    @map("booking_id")
  ticketTypeId String    @map("ticket_type_id")
  quantity     Int
  unitPrice    Decimal   @map("unit_price") @db.Decimal(12, 2)
  subtotal     Decimal   @db.Decimal(12, 2)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  booking      Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  tickets      Ticket[]

  @@unique([bookingId, ticketTypeId])
  @@index([ticketTypeId])
  @@map("booking_items")
}

model Ticket {
  id           String       @id @default(cuid())
  ticketCode   String       @unique @map("ticket_code")
  bookingId    String       @map("booking_id")
  bookingItemId String      @map("booking_item_id")
  eventId      String       @map("event_id")
  userId       String       @map("user_id")
  ticketTypeId String       @map("ticket_type_id")
  qrPayload    String       @map("qr_payload") @db.Text
  status       TicketStatus @default(VALID)
  checkedInAt  DateTime?    @map("checked_in_at")
  checkedInBy  String?      @map("checked_in_by")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingItem  BookingItem  @relation(fields: [bookingItemId], references: [id], onDelete: Restrict)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Restrict)
  user         User         @relation("TicketOwner", fields: [userId], references: [id], onDelete: Restrict)
  ticketType   TicketType   @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  checker      User?        @relation("TicketCheckedInBy", fields: [checkedInBy], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([bookingItemId])
  @@index([eventId])
  @@index([userId])
  @@index([ticketTypeId])
  @@index([status])
  @@index([checkedInBy])
  @@map("tickets")
}

model FavoriteEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("favorite_events")
}

model EventReview {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  bookingId String   @unique @map("booking_id")
  rating    Int
  comment   String?  @db.Text
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Restrict)
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, isVisible])
  @@map("event_reviews")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  action      String
  module      String
  description String   @db.Text
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module, action])
  @@index([createdAt])
  @@map("activity_logs")
}
